generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  
}

enum Role {
  USER
  ADMIN
}

enum Status {
  PENDING
  APPROVED
  DENIED
}

model User {
  id            String   @id @default(uuid())
  clerkUserId   String   @unique
  uniqueAdminId String   @unique 
  securityPin   String   
  fullName      String
  email         String   @unique
  designation   String
  lga           String
  state         String
  phoneNumber   String?
  role          Role     @default(USER)
  status        Status   @default(PENDING) 
  emailSent     Boolean  @default(false)   
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==========================================
// NEW: Farmer Registration Model for Overview
// ==========================================
model Farmer {
  id                     String   @id @default(uuid())
  fullName               String
  age                    Int
  gender                 String
  highestEducation       String
  maritalStatus          String
  householdSize          Int?
  state                  String
  lga                    String
  cluster                String
  userGroup              String
  nameOfChosenEnterprise String
  typeOfEnterprise       String
  estimatedAnnualIncome  Float
  phoneNumber            String
  photoUrl               String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}